{
  "id": "temporal",
  "type": "table",
  "version": "1.0.0",
  "status": "stable",
  "title": "Temporal",
  "description": "Table for Geosearch tests with temporal data",
  "temporal": {
    "identifier": "volgnummer",
    "dimensions":  {
      "geldigOp": [
        "beginGeldigheid",
        "eindGeldigheid"
      ]
    }
  },
  "schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "additionalProperties": false,
    "mainGeometry": "geometrie",
    "identifier": [
      "identificatie",
      "volgnummer"
    ],
    "required": [
      "schema",
      "identificatie",
      "volgnummer"
    ],
    "display": "naam",
    "properties": {
      "schema": {
        "$ref": "https://schemas.data.amsterdam.nl/schema@v4.2.0#/definitions/schema"
      },
      "identificatie": {
        "type": "string",
        "title": "ID",
        "description": "Unieke aanduiding van record"
      },
      "volgnummer": {
        "type": "integer",
        "title": "Volgnummer",
        "description": "Uniek volgnummer van de toestand van het object"
      },
      "beginGeldigheid": {
        "type": "string",
        "title": "Object geldigheid startdatum",
        "format": "date-time",
        "description": "De begindatum van de geldigheid van een bepaalde combinatie van gegevens over een object"
      },
      "eindGeldigheid": {
        "type": "string",
        "title": "Object geldigheid einddatum",
        "format": "date-time",
        "description": "De einddatum van de geldigheid van een bepaalde combinatie van gegevens over een object"
      },
      "naam": {
        "type": "string",
        "title": "Naam",
        "description": "Naam van het object"
      },
      "geometrie": {
        "$ref": "https://geojson.org/schema/Point.json",
        "description": "Geometrie van het object"
      }
    }
  }
}
